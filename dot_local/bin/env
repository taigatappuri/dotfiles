#!/bin/sh
# 未追加の場合だけ実行ファイルのパスをPATHへ加える
# 判定を単純化するためPATHの両端にコロンを付ける
case ":${PATH}:" in
  *:"$HOME/.local/bin":*) ;;
  *)
    # システム側の実行ファイルを上書きできるよう先頭へ追加する
    export PATH="$HOME/.local/bin:$PATH"
    ;;
esac

case ":${PATH}:" in
  *:"$HOME/.npm-global/bin":*) ;;
  *)
    # npm globalで導入したCLIを古いローカル/システム側の実行ファイルより優先する
    export PATH="$HOME/.npm-global/bin:$PATH"
    ;;
esac
